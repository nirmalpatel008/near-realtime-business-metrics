# Copy this file to .env for local use.
# Never commit .env with real credentials or passwords.

AWS_PROFILE=summit-demo
AWS_REGION=us-east-1
STACK=dms-demo

# Set this locally before deploying or connecting.
# Use a strong unique demo password, not this placeholder.
DB_PASSWORD=<set-a-strong-demo-password>
DB_USER=admin
DB_NAME=demo

# Optional OpenAI-native extension for AI operations briefs.
# Keep the real key only in local .env or your shell environment.
OPENAI_API_KEY=<set-your-openai-api-key>
OPENAI_MODEL=gpt-5.5

# Optional: set after deploy, or resolve from CloudFormation outputs.
SRC_HOST=<source-rds-endpoint>
TGT_HOST=<target-rds-endpoint>

# Optional: lock DB access to your current IP when deploying.
MY_IP_CIDR=<your-public-ip>/32
